<mesh>
	<buffers>
		<buffer>
			<material>
				<color>1,1,1,1</color>
				<texture type="color2D">
				  <layer name="textureColor">data/plane2D/flame.png</layer>
				</texture>
				<depthWrite>true</depthWrite>
				<light>false</light>
				<shadow>false</shadow>
				<shininess>1</shininess>
				<blendMode>alpha</blendMode>
				<refraction>false</refraction>
				<refractIndex>0.9</refractIndex>
				<reflection>false</reflection>	
				<culling>false</culling>
				<shader>data/shader.vert,data/shader.frag</shader>
			</material>
			<meshData>data/plane2D/plane2D.obj</meshData>
		</buffer>
	</buffers>
</mesh>